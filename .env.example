# ====================================================================
# .env.example - תבנית למשתני סביבה לפרויקט "צוות הסוכנים"
# ====================================================================
# העתק לקובץ .env ומלא את הערכים האמיתיים:
#   cp .env.example .env   (Linux/Mac)
#   Copy-Item .env.example .env   (PowerShell)
#
# הקובץ .env לא נדחף ל-Git (מוגדר ב-.gitignore).
# רק קובץ זה (.env.example) נשמר ברימוט - בלי סודות.
# ====================================================================


# --- Claude / Anthropic --------------------------------------------
# מפתח API של Anthropic (https://console.anthropic.com/)
# נדרש אם רץ קוד שמשתמש ב-SDK ישירות. בתוך Claude Code עצמו - לא חובה.
ANTHROPIC_API_KEY=


# --- יובל (מעצב התמונות) -------------------------------------------
# מפתח OpenAI ליצירת תמונות דרך מודל gpt-image-2.
OPENAI_API_KEY=          # ליצירת תמונות (gpt-image-2)
# STABILITY_API_KEY=       # אופציונלי - ל-Stable Diffusion / Stability AI


# --- חן (חוקרת) ----------------------------------------------------
# שירות חיפוש באינטרנט. בחר אחד.
# TAVILY_API_KEY=
# BRAVE_SEARCH_API_KEY=
# SERPER_API_KEY=


# --- יעל (כותבת תוכן) ----------------------------------------------
# בינתיים עובדת רק עם Claude - אין משתנים חיצוניים.
